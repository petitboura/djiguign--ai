# Copier en .env.local (jamais commité) et remplir avec les vraies valeurs.

# Mêmes valeurs que côté Streamlit (assistant-etudiants/RAILWAY_DEPLOY.md) :
# NEXT_PUBLIC_SUPABASE_URL = SUPABASE_URL
NEXT_PUBLIC_SUPABASE_URL=

# Attention : ceci est la clé ANON (publique, restreinte par les policies
# RLS), PAS SUPABASE_SECRET utilisée côté backend. Dans Supabase → Settings
# → API → "anon public".
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# URL du backend FastAPI (api/ dans assistant-etudiants).
# En local : http://localhost:8000
# Une fois déployé : l'URL Railway du service API (distinct du service
# Streamlit existant).
NEXT_PUBLIC_API_URL=http://localhost:8000

# Étape D.3 : URL publique de l'app Streamlit (le chat, voir
# PIVOT_SOCIAL.md — reste en Streamlit définitivement). Doit correspondre
# à la même valeur que le secret URL_RETOUR_APP côté Streamlit
# (assistant-etudiants), sinon le lien "?agent=..." pointera au mauvais
# endroit. Exposé en NEXT_PUBLIC_ car utilisé côté client (composant
# BoutonUtiliser) pour construire le lien iframe/plein écran.
NEXT_PUBLIC_STREAMLIT_URL=
